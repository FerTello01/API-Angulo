# EVVM Deployment on Base
# https://www.evvm.info/docs/QuickStart

# Host chain — Base Sepolia (testing)
RPC_URL="https://sepolia.base.org"

# Base Mainnet (production)
# RPC_URL="https://mainnet.base.org"

# EVVM Registry (always Ethereum Sepolia)
EVVM_REGISTRATION_RPC_URL="https://gateway.tenderly.co/public/sepolia"

# Contract verification — Etherscan v2 works for Base
ETHERSCAN_API="your_basescan_api_key"

# ── Suggested EVVM token config for API Angulo ──
# EVVM Name:        API Angulo EVVM
# Principal Token:  Impact Token
# Symbol:           IMPACT
#
# Admin:         your team wallet
# Golden Fisher: relayer wallet (RELAYER_PRIVATE_KEY address)
# Activator:     relayer wallet

# ── After deployment, copy to API Angulo .env ──
# EVVM_CORE_ADDRESS=0x...
# EVVM_STAKING_ADDRESS=0x...
# EVVM_ID=1001
