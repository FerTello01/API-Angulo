# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
WEB_APP_URL=http://localhost:3001

# Base Network — "sepolia" (testing) or "mainnet" (production)
BASE_NETWORK=sepolia
BASE_RPC_URL=https://sepolia.base.org

# Operational Relayer Wallet (backend signs all on-chain transactions)
RELAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# EAS — Predeployed on Base (OP Stack) — no need to deploy manually
# https://docs.attest.org/docs/welcome
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021
EAS_SCHEMA_REGISTRY_ADDRESS=0x4200000000000000000000000000000000000020

# Register schema first: npm run register-schema
EAS_IMPACT_SCHEMA_UID=0xYOUR_SCHEMA_UID_HERE

# EVVM — Deploy with evvm-cli on Base (see docs/DEPLOY-BASE.md)
# https://www.evvm.info/docs/QuickStart
EVVM_CORE_ADDRESS=0xYOUR_EVVM_CORE_ADDRESS
EVVM_STAKING_ADDRESS=0xYOUR_EVVM_STAKING_ADDRESS
EVVM_ID=0

# Transaction tuning
TX_CONFIRMATIONS=1
TX_TIMEOUT_MS=120000
TX_MAX_RETRIES=3
