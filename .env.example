# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Gravity Network — use "mainnet" (L1, chain 127001) or "alpha" (legacy L2, chain 1625) or "sepolia"
GRAVITY_NETWORK=mainnet
GRAVITY_RPC_URL=https://mainnet-rpc.gravity.xyz

# Operational Relayer Wallet (backend signs all on-chain transactions)
RELAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed ImpactCertificateRegistry contract address
IMPACT_REGISTRY_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Transaction tuning
TX_CONFIRMATIONS=1
TX_TIMEOUT_MS=120000
TX_MAX_RETRIES=3
